{
  "connectorName": "tableProject",
  "operationName": "sendBatch",
  "title": "send batch",
  "help": "Send batch of messages",
  "elements": [
    {
      "type": "attributeGroup",
      "value": {
        "groupName": "General",
        "elements": [
          {
            "type": "attribute",
            "value": {
              "name": "configRef",
              "displayName": "Connection",
              "inputType": "connection",
              "allowedConnectionTypes": [
                "tableProject_TableClient"
              ],
              "defaultType": "connection.tableProject_TableClient",
              "defaultValue": "",
              "required": "true",
              "helpTip": "Connection to be used"
            }
          },
          {
            "type": "attributeGroup",
            "value": {
              "groupName": "Input Variables",
              "elements": [
                {
                  "type": "attribute",
                  "value": {
                    "name": "messageCount",
                    "displayName": "messageCount",
                    "inputType": "stringOrExpression",
                    "defaultValue": "",
                    "required": true,
                    "helpTip": "",
                    "validateType": "regex",
                    "matchPattern": "^(-?\\d+|\\$\\{.+\\})$"
                  }
                },
                {
                  "type": "attribute",
                  "value": {
                    "name": "messagesInputMode",
                    "displayName": "messages Input Mode",
                    "inputType": "combo",
                    "comboValues": [
                      "Table",
                      "JSON"
                    ],
                    "defaultValue": "Table",
                    "required": "true",
                    "helpTip": "Choose input mode: Table for interactive entry, JSON for array expression"
                  }
                },
                {
                  "type": "table",
                  "value": {
                    "name": "messages",
                    "displayName": "messages",
                    "title": "messages",
                    "description": "Configure messages entries",
                    "tableKey": "body",
                    "tableValue": "messageId",
                    "enableCondition": [
                      {
                        "messagesInputMode": "Table"
                      }
                    ],
                    "elements": [
                      {
                        "type": "attribute",
                        "value": {
                          "name": "body",
                          "displayName": "Body",
                          "inputType": "stringOrExpression",
                          "required": true,
                          "helpTip": "Body"
                        }
                      },
                      {
                        "type": "attribute",
                        "value": {
                          "name": "contentType",
                          "displayName": "ContentType",
                          "inputType": "stringOrExpression",
                          "required": true,
                          "helpTip": "ContentType"
                        }
                      },
                      {
                        "type": "attribute",
                        "value": {
                          "name": "messageId",
                          "displayName": "MessageId",
                          "inputType": "stringOrExpression",
                          "required": true,
                          "helpTip": "MessageId"
                        }
                      }
                    ]
                  }
                },
                {
                  "type": "attribute",
                  "value": {
                    "name": "messagesJson",
                    "displayName": "messages (JSON Array)",
                    "inputType": "stringOrExpression",
                    "defaultValue": "",
                    "required": true,
                    "helpTip": "Enter JSON array of messages objects. Example: [{\"field1\": \"value1\", ...}, ...]",
                    "validateType": "json",
                    "matchPattern": "",
                    "enableCondition": [
                      {
                        "messagesInputMode": "JSON"
                      }
                    ]
                  }
                }
              ]
            }
          },
          {
            "type": "attributeGroup",
            "value": {
              "groupName": "Output",
              "elements": [
                {
                  "type": "attribute",
                  "value": {
                    "name": "responseVariable",
                    "displayName": "Output Variable Name",
                    "inputType": "string",
                    "defaultValue": "",
                    "required": "false",
                    "helpTip": "The target variable in which the output of the operation will be stored"
                  }
                },
                {
                  "type": "attribute",
                  "value": {
                    "name": "overwriteBody",
                    "displayName": "Overwrite Message Body",
                    "inputType": "checkbox",
                    "defaultValue": "false",
                    "helpTip": "Replace the Message Body in Message Context with the output payload of the operation (This will remove the payload from the above variable. But other elements such as headers and attributes will remain).",
                    "required": "false"
                  }
                }
              ]
            }
          }
        ]
      }
    }
  ]
}